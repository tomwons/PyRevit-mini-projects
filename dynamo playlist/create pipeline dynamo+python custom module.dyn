    {
      "ConcreteType": "Dynamo.Graph.Nodes.CodeBlockNodeModel, DynamoCore",
      "Id": "e8d9d04df0514a19a7fe98a2a359271c",
      "NodeType": "CodeBlockNode",
      "Inputs": [
        {
          "Id": "ebc8eed10cf24a55b2edf18e5251c2e1",
          "Name": "l",
          "Description": "l",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "b3e3717dafc348f3a63935859083d833",
          "Name": "function",
          "Description": "DesignScript.Builtin.Get.ValueAtIndex(l, 0)",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Umożliwia bezpośrednie utworzenie kodu DesignScript.",
      "Code": "l[0];"
    },
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "# -*- coding: utf-8 -*-\r\nimport clr\r\nimport math\r\n\r\nclr.AddReference('RevitAPI')\r\nfrom Autodesk.Revit.DB import *\r\nfrom Autodesk.Revit.DB.Plumbing import *\r\n\r\nclr.AddReference('RevitServices')\r\nimport RevitServices\r\nfrom RevitServices.Persistence import DocumentManager\r\n\r\ndoc = DocumentManager.Instance.CurrentDBDocument\r\n\r\n# --- WEJŚCIA ---\r\nraw_system = IN[0]\r\nraw_type = IN[1]\r\nraw_elements = IN[2] if isinstance(IN[2], list) else [IN[2]]\r\n\r\nraport = []\r\n\r\n# --- FUNKCJE POMOCNICZE ---\r\n\r\ndef force_unwrap(item):\r\n    if item is None: return None\r\n    if hasattr(item, \"InternalElement\"): return item.InternalElement\r\n    return item\r\n\r\ndef get_line_intersection_2d(p1, p2, p3, p4):\r\n    den = (p4.Y - p3.Y) * (p2.X - p1.X) - (p4.X - p3.X) * (p2.Y - p1.Y)\r\n    if den == 0: return None \r\n    ua = ((p4.X - p3.X) * (p1.Y - p3.Y) - (p4.Y - p3.Y) * (p1.X - p3.X)) / den\r\n    ub = ((p2.X - p1.X) * (p1.Y - p3.Y) - (p2.Y - p1.Y) * (p1.X - p3.X)) / den\r\n    if 0.01 < ua < 0.99 and 0.01 < ub < 0.99:\r\n        return XYZ(p1.X + ua * (p2.X - p1.X), p1.Y + ua * (p2.Y - p1.Y), 0)\r\n    return None\r\n\r\ndef dist_pt_to_line_2d(p, a, b):\r\n    area = abs((b.Y - a.Y) * p.X - (b.X - a.X) * p.Y + b.X * a.Y - b.Y * a.X)\r\n    line_len = math.sqrt((b.Y - a.Y)**2 + (b.X - a.X)**2)\r\n    return area / line_len if line_len > 0 else 0\r\n\r\ndef get_conn(p_obj, pt):\r\n    if not p_obj: return None\r\n    for c in p_obj.ConnectorManager.Connectors:\r\n        if c.Origin.DistanceTo(pt) < 0.5: return c\r\n    return None\r\n\r\n# --- LOGIKA ANALIZY ---\r\n\r\ndef analyze_intersections(data_list):\r\n    L, T, X = [], [], []\r\n    tol = 0.06 # ok. 2 cm (tolerancja styku)\r\n    height_limit = 1.0 # ok. 30 cm (limit odległości pionowej rur od siebie)\r\n\r\n    for i in range(len(data_list)):\r\n        for j in range(i + 1, len(data_list)):\r\n            l1, l2 = data_list[i][\"curve\"], data_list[j][\"curve\"]\r\n            p1s, p1e = l1.GetEndPoint(0), l1.GetEndPoint(1)\r\n            p2s, p2e = l2.GetEndPoint(0), l2.GetEndPoint(1)\r\n\r\n            # --- NOWY FILTR: Sprawdzenie wysokości ---\r\n            # Liczymy średnie Z dla obu linii\r\n            z1_avg = (p1s.Z + p1e.Z) / 2\r\n            z2_avg = (p2s.Z + p2e.Z) / 2\r\n            \r\n            # Jeśli rury są od siebie oddalone w pionie o więcej niż limit, pomiń\r\n            if abs(z1_avg - z2_avg) > height_limit:\r\n                continue\r\n            # ------------------------------------------\r\n\r\n            # 1. SPRAWDZAMY CZWÓRNIK (X)\r\n            cross_pt = get_line_intersection_2d(p1s, p1e, p2s, p2e)\r\n            if cross_pt:\r\n                z_avg = (z1_avg + z2_avg) / 2\r\n                X.append({\"id_a\": data_list[i][\"id\"], \"id_b\": data_list[j][\"id\"], \"point\": XYZ(cross_pt.X, cross_pt.Y, z_avg)})\r\n                continue\r\n\r\n            # 2. SPRAWDZAMY STYK KOŃCÓW (L)\r\n            found = False\r\n            for p1 in [p1s, p1e]:\r\n                for p2 in [p2s, p2e]:\r\n                    if p1.DistanceTo(p2) < tol:\r\n                        L.append({\"id_a\": data_list[i][\"id\"], \"id_b\": data_list[j][\"id\"], \"point\": p1})\r\n                        found = True; break\r\n                if found: break\r\n            if found: continue\r\n\r\n            # 3. SPRAWDZAMY TRÓJNIK (T)\r\n            for p in [p1s, p1e]:\r\n                if dist_pt_to_line_2d(p, p2s, p2e) < tol:\r\n                    T.append({\"id_a\": data_list[i][\"id\"], \"id_b\": data_list[j][\"id\"], \"point\": p, \"main_pipe\": data_list[j][\"id\"]})\r\n                    found = True; break\r\n            if found: continue\r\n\r\n            for p in [p2s, p2e]:\r\n                if dist_pt_to_line_2d(p, p1s, p1e) < tol:\r\n                    T.append({\"id_a\": data_list[j][\"id\"], \"id_b\": data_list[i][\"id\"], \"point\": p, \"main_pipe\": data_list[i][\"id\"]})\r\n                    break\r\n    return {\"l\": L, \"t\": T, \"x\": X}\r\n\r\ndef create_crosses(document, p_map, x_data):\r\n    for item in x_data:\r\n        r1, r2 = p_map.get(item[\"id_a\"]), p_map.get(item[\"id_b\"])\r\n        pt = item[\"point\"]\r\n        try:\r\n            r1b_id = PlumbingUtils.BreakCurve(document, r1.Id, pt)\r\n            r2b_id = PlumbingUtils.BreakCurve(document, r2.Id, pt)\r\n            document.Regenerate()\r\n            r1b, r2b = document.GetElement(r1b_id), document.GetElement(r2b_id)\r\n            c = [get_conn(r1, pt), get_conn(r1b, pt), get_conn(r2, pt), get_conn(r2b, pt)]\r\n            if all(c): document.Create.NewCrossFitting(c[0], c[1], c[2], c[3])\r\n        except: pass\r\n\r\ndef create_tees(document, p_map, t_data):\r\n    for item in t_data:\r\n        branch = p_map.get(item[\"id_a\"]) if item[\"id_a\"] != item.get(\"main_pipe\") else p_map.get(item[\"id_b\"])\r\n        main = p_map.get(item.get(\"main_pipe\"))\r\n        pt = item[\"point\"]\r\n        try:\r\n            m2_id = PlumbingUtils.BreakCurve(document, main.Id, pt)\r\n            document.Regenerate()\r\n            m2 = document.GetElement(m2_id)\r\n            cb, cm1, cm2 = get_conn(branch, pt), get_conn(main, pt), get_conn(m2, pt)\r\n            if cb and cm1 and cm2: document.Create.NewTeeFitting(cm1, cm2, cb)\r\n        except: pass\r\n\r\ndef create_elbows(document, p_map, l_data):\r\n    for item in l_data:\r\n        r1, r2 = p_map.get(item[\"id_a\"]), p_map.get(item[\"id_b\"])\r\n        c1, c2 = get_conn(r1, item[\"point\"]), get_conn(r2, item[\"point\"])\r\n        if c1 and c2:\r\n            try: document.Create.NewElbowFitting(c1, c2)\r\n            except: pass\r\n\r\n# --- WYKONANIE W GRUPIE TRANSAKCJI ---\r\n\r\nextracted_geo = []\r\nfor item in raw_elements:\r\n    el = force_unwrap(item)\r\n    geom = getattr(el, \"GeometryCurve\", getattr(getattr(el, \"Location\", None), \"Curve\", None))\r\n    if isinstance(geom, Line): extracted_geo.append({\"id\": el.Id, \"curve\": geom})\r\n\r\nif extracted_geo:\r\n    # 1. Inicjalizacja Grupy\r\n    tg = TransactionGroup(doc, \"Generowanie Systemu Rurowego\")\r\n    tg.Start()\r\n\r\n    # 2. Transakcja na rury\r\n    pipes_map = {}\r\n    t_pipes = Transaction(doc, \"Tworzenie Rur\")\r\n    t_pipes.Start()\r\n    lvl_id = FilteredElementCollector(doc).OfClass(Level).FirstElementId()\r\n    s_id, t_id = force_unwrap(raw_system).Id, force_unwrap(raw_type).Id\r\n    for data in extracted_geo:\r\n        p = Pipe.Create(doc, s_id, t_id, lvl_id, data[\"curve\"].GetEndPoint(0), data[\"curve\"].GetEndPoint(1))\r\n        pipes_map[data[\"id\"]] = p\r\n    t_pipes.Commit()\r\n\r\n    # 3. Analiza kolizji\r\n    wyniki = analyze_intersections(extracted_geo)\r\n\r\n    # 4. Transakcja na złączki (wszystkie typy w jednej)\r\n    t_fittings = Transaction(doc, \"Wstawianie Złączek\")\r\n    t_fittings.Start()\r\n    \r\n    create_crosses(doc, pipes_map, wyniki[\"x\"])\r\n    create_tees(doc, pipes_map, wyniki[\"t\"])\r\n    create_elbows(doc, pipes_map, wyniki[\"l\"])\r\n    \r\n    t_fittings.Commit()\r\n\r\n    # 5. Zamknięcie grupy (Assimilate łączy t_pipes i t_fittings w jedną pozycję Undo)\r\n    tg.Assimilate()\r\n    \r\n    OUT = \"Sukces: L={}, T={}, X={}\".format(len(wyniki[\"l\"]), len(wyniki[\"t\"]), len(wyniki[\"x\"]))\r\nelse:\r\n    OUT = \"Brak danych wejściowych.\"",
      "Engine": "CPython3",
      "VariableInputPorts": true,
      "Id": "eddc6b35ac05452cbb54396c14129a48",
      "NodeType": "PythonScriptNode",
      "Inputs": [
        {
          "Id": "367f5e17ab54499bae17955670d87c5a",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
