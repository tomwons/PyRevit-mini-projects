        {
          "Id": "32624a766a9a4e4f871fe17e49d817a2",
          "Name": "User Inputs",
          "Description": "wartość zwracana",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "d44e79cde20d4dc69ae4a2d245e75726",
          "Name": "Was Run ",
          "Description": "wartość zwracana",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "f094255b2cf84bf2bd81e94a8db96804",
          "Name": "Was Cancelled",
          "Description": "wartość zwracana",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Auto",
      "Description": "Create a form with multiple inputs. \r\nsee www.data-shapes.net for tutorials and infos!"
    },
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "# -*- coding: utf-8 -*-\r\nimport clr\r\n\r\n# Importujemy Revit API, żeby wyciągnąć parametry nazw\r\nclr.AddReference('RevitAPI')\r\nfrom Autodesk.Revit.DB import *\r\n\r\ndef force_unwrap(item):\r\n    \"\"\"Funkcja do odpakowania elementów z formatu Dynamo do Revit API\"\"\"\r\n    if item is None: return None\r\n    if hasattr(item, \"InternalElement\"): \r\n        return item.InternalElement\r\n    return item\r\n\r\n# 1. Pobieramy obiekty z wejścia IN[0] (podłącz tutaj 'All Elements of Class')\r\ninput_data = IN[0] if isinstance(IN[0], list) else [IN[0]]\r\nelements = [force_unwrap(x) for x in input_data]\r\n\r\nnames = []\r\nclean_elements = []\r\n\r\nfor el in elements:\r\n    if el is None: continue\r\n    try:\r\n        # Próbujemy pobrać \"Nazwę typu\" (Symbol Name)\r\n        p = el.get_Parameter(BuiltInParameter.SYMBOL_NAME_PARAM)\r\n        n = p.AsString() if p and p.AsString() else el.Name\r\n        \r\n        # Jeśli nazwa jest pusta, używamy domyślnego .Name\r\n        if not n: n = \"Nieznany typ\"\r\n        \r\n        names.append(n)\r\n        clean_elements.append(el)\r\n    except:\r\n        # Jeśli coś pójdzie nie tak, bierzemy co się da\r\n        names.append(str(el.Id))\r\n        clean_elements.append(el)\r\n\r\n# 2. WYJŚCIE:\r\n# OUT[0] to lista nazw (podłącz do 'keys' w UI.DropDown.Data)\r\n# OUT[1] to lista fizycznych obiektów (podłącz do 'values' w UI.DropDown.Data)\r\nOUT = [names, clean_elements]",
      "Engine": "CPython3",
      "VariableInputPorts": true,
      "Id": "7f3094c85a6f4fae9d74ece636e7734b",
      "NodeType": "PythonScriptNode",
      "Inputs": [
        {
          "Id": "cf23f5773a1740928baeeb3d50105e2b",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "c9f515e3f80e4016b6784d5aa12e10cb",
          "Name": "OUT",
          "Description": "Wynik skryptu w języku Python",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Uruchamia osadzony skrypt języka Python."
    },
